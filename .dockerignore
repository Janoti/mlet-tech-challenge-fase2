# Versionamento
.git
.gitignore
.gitattributes

# Ambientes virtuais e caches Python
.venv
venv
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov

# Dados e modelos: entram via volume / DVC, nunca pela imagem.
data
models
mlruns
mlartifacts
.dvc/cache
.dvc/tmp
# Exceção: o stage `serving-local` bakeia estes modelos treinados na imagem
# (deploy imutável, MODEL_SOURCE=local). Os demais stages não os copiam.
!models/embedding.pkl
!models/baseline.pkl

# Editores / SO
.vscode
.idea
.DS_Store
Thumbs.db

# Notebooks (não vão para a imagem de runtime)
notebooks
*.ipynb_checkpoints

# Variáveis sensíveis
.env
.env.*
!.env.example

# Documentação e meta
# README.md é necessário no estágio de build (poetry-core lê o `readme` do
# pyproject ao instalar o pacote). O estágio runtime não o copia.
docs
