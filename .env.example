# ============================================================================
# Tech Challenge Fase 2 — Variáveis de ambiente (exemplo)
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env` e ajuste os valores localmente.
# O .env real NÃO entra no Git (ver .gitignore). Esta é a forma recomendada
# pelo Clean Code para externalizar configuração sensível e variável por
# ambiente — nada de "magic strings" espalhadas pelo código.
# ============================================================================

# ---------- Reprodutibilidade ----------
# Semente global para gerar números aleatórios em numpy/torch/random.
# Fixá-la é requisito do enunciado ("seeds fixados").
RANDOM_SEED=42

# ---------- Geração de dataset sintético (Etapa 1) ----------
# Número de usuários e itens distintos no catálogo simulado.
NUM_USERS=2000
NUM_ITEMS=500
# Mínimo exigido pelo enunciado: >= 10.000 interações user-item.
NUM_INTERACTIONS=50000

# Diretórios de saída (relativos à raiz do projeto).
DATA_RAW_DIR=data/raw
DATA_INTERIM_DIR=data/interim
DATA_PROCESSED_DIR=data/processed

# ---------- MLflow (será usado a partir da Etapa 3) ----------
# Tracking URI: local por padrão; pode apontar para um servidor remoto.
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=recsys-ecommerce

# ---------- Logging ----------
# Nível de log da aplicação (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
